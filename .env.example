# PostgreSQL connection string
# En macOS/Homebrew suele bastar el usuario del sistema sin contraseña:
# postgresql://TU_USUARIO@localhost:5432/palilleria?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/palilleria?schema=public"

# Auth.js / NextAuth (requerido para login y sesión)
# Genera un secreto: openssl rand -base64 32
AUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# File storage
STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH="./storage"
MAX_UPLOAD_SIZE_MB=50

# Experimental (dev/staging only) — OCR del cajetín en tab Automatización
EXPERIMENTAL_TITLE_BLOCK_OCR=true
