{
  "name": "palilleria-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:generate && next dev --turbopack",
    "build": "DATABASE_URL=${DATABASE_URL:-postgresql://user:password@localhost:5432/palilleria?schema=public} prisma generate && next build",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://user:password@localhost:5432/palilleria?schema=public} prisma generate",
    "postinstall": "npm run db:generate",
    "start": "next start",
    "lint": "eslint",
    "verify:takeoff": "tsx scripts/verify-takeoff-pure.ts",
    "verify:trameado": "tsx scripts/verify-trameado-model.ts",
    "inspect:pdf": "tsx scripts/inspect-pdf-pages.ts",
    "verify:title-block-crop": "tsx scripts/verify-title-block-crop.ts",
    "check:tesseract": "tsx scripts/check-tesseract.ts",
    "benchmark:ocr": "tsx scripts/benchmark-title-block-ocr.ts",
    "research:auto-takeoff": "tsx scripts/research-auto-takeoff-from-pdf.ts",
    "research:trameado-auto": "tsx scripts/research-trameado-auto.ts",
    "research:trameado-vector": "tsx scripts/research-trameado-vector.ts",
    "validate:trameado-functional": "tsx scripts/validate-trameado-functional.ts",
    "research:out-of-bom": "tsx scripts/research-out-of-bom-items.ts",
    "benchmark:auto-takeoff": "tsx scripts/benchmark-auto-takeoff.ts",
    "validate:auto-takeoff-golden": "tsx scripts/validate-auto-takeoff-golden.ts",
    "validate:auto-takeoff-business": "tsx scripts/validate-auto-takeoff-business.ts",
    "validate:auto-takeoff-business-rules": "tsx scripts/validate-auto-takeoff-business-rules.ts",
    "verify:auto-takeoff": "tsx scripts/verify-auto-takeoff-parse.ts",
    "smoke:auto-takeoff-beta": "npm run verify:auto-takeoff && playwright test tests/e2e/experimental-auto-takeoff-import.spec.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:e2e": "tsx scripts/seed-e2e.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bcrypt": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
